{
  "name": "pi-turn-profiler",
  "version": "0.1.0",
  "description": "Pi extension for profiling LLM turn performance: TPS, tokens, cache, cost, and tool execution time.",
  "keywords": [
    "pi",
    "pi-extension",
    "profiler",
    "tps"
  ],
  "license": "MIT",
  "author": "",
  "files": [
    "index.ts",
    "src",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --test tests/*.test.ts",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "pre-commit": "prek run"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@j178/prek": "^0.4.4",
    "@types/node": "^24.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
